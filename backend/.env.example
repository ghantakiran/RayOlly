# ============================================================
# RayOlly Backend Environment Variables
# Copy to .env and adjust for your environment
# ============================================================

# ── General ──────────────────────────────────────────────────
RAYOLLY_ENV=development
RAYOLLY_LOG_LEVEL=debug
RAYOLLY_DEBUG=true
RAYOLLY_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── API Server ───────────────────────────────────────────────
RAYOLLY_API_HOST=0.0.0.0
RAYOLLY_API_PORT=8080
RAYOLLY_API_WORKERS=1
RAYOLLY_API_CORS_ORIGINS=http://localhost:3000

# ── ClickHouse ───────────────────────────────────────────────
RAYOLLY_CLICKHOUSE_HOST=localhost
RAYOLLY_CLICKHOUSE_PORT=9000
RAYOLLY_CLICKHOUSE_HTTP_PORT=8123
RAYOLLY_CLICKHOUSE_USER=rayolly
RAYOLLY_CLICKHOUSE_PASSWORD=rayolly_dev
RAYOLLY_CLICKHOUSE_DATABASE=default
RAYOLLY_CLICKHOUSE_INGEST_USER=rayolly_ingest
RAYOLLY_CLICKHOUSE_INGEST_PASSWORD=rayolly_ingest_dev

# ── NATS ─────────────────────────────────────────────────────
RAYOLLY_NATS_URL=nats://localhost:4222
RAYOLLY_NATS_TOKEN=rayolly_dev_token
RAYOLLY_NATS_MAX_RECONNECTS=60
RAYOLLY_NATS_RECONNECT_WAIT_MS=2000

# ── Redis ────────────────────────────────────────────────────
RAYOLLY_REDIS_URL=redis://localhost:6379/0
RAYOLLY_REDIS_MAX_CONNECTIONS=20

# ── MinIO / S3 ──────────────────────────────────────────────
RAYOLLY_MINIO_ENDPOINT=localhost:9002
RAYOLLY_MINIO_ACCESS_KEY=minioadmin
RAYOLLY_MINIO_SECRET_KEY=minioadmin
RAYOLLY_MINIO_USE_SSL=false
RAYOLLY_MINIO_BUCKET=rayolly-data

# ── PostgreSQL ───────────────────────────────────────────────
RAYOLLY_POSTGRES_DSN=postgresql://rayolly:rayolly_dev@localhost:5432/rayolly
RAYOLLY_POSTGRES_POOL_SIZE=10
RAYOLLY_POSTGRES_POOL_MAX_OVERFLOW=20

# ── Auth / JWT ───────────────────────────────────────────────
RAYOLLY_JWT_SECRET=change-me-in-production
RAYOLLY_JWT_ALGORITHM=HS256
RAYOLLY_JWT_EXPIRATION_MINUTES=60
RAYOLLY_JWT_REFRESH_EXPIRATION_DAYS=7

# ── Ingestion ────────────────────────────────────────────────
RAYOLLY_INGEST_BATCH_SIZE=5000
RAYOLLY_INGEST_FLUSH_INTERVAL_MS=1000
RAYOLLY_INGEST_MAX_QUEUE_SIZE=100000

# ── AI / LLM ────────────────────────────────────────────────
RAYOLLY_AI_PROVIDER=openai
RAYOLLY_AI_MODEL=gpt-4o
RAYOLLY_AI_API_KEY=
RAYOLLY_AI_MAX_TOKENS=4096
RAYOLLY_AI_TEMPERATURE=0.1

# ── Feature Flags ────────────────────────────────────────────
RAYOLLY_FEATURE_AI_QUERY=true
RAYOLLY_FEATURE_ANOMALY_DETECTION=true
RAYOLLY_FEATURE_ALERTING=true
